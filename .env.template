# Database (used by alembic and runtime engine)
DATABASE_URL=postgresql+asyncpg://price_tracker:price_tracker@localhost:5432/price_tracker

# OpenRouter LLM (REQ INFRA-03, INFRA-04)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=https://prices.example.com
OPENROUTER_APP_TITLE=Price Tracker

# Price parser model cascade (comma-separated, tried left-to-right)
PRICE_PARSER_MODEL=meta-llama/llama-4-scout
PRICE_PARSER_FALLBACK_MODEL=anthropic/claude-haiku-4.5
PRICE_PARSER_MODEL_CASCADE=${PRICE_PARSER_MODEL},${PRICE_PARSER_FALLBACK_MODEL}

# SMTP / Email alerts (REQ INFRA-02)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=price-tracker@example.com

# Admin UI auth — upstream IAP header trust (REQ AUTH-01, AUTH-02)
# Only requests with X-Auth-Request-Email matching this value are admitted.
ALLOWED_ENTRA_EMAIL=magnus.ternstrom@example.com

# MCP bearer token (REQ AUTH-04, MCP-05)
# Used on the mcp.<domain> subdomain (IAP-bypassed).
MCP_BEARER_TOKEN=replace-with-a-long-random-string
